# ==========================================================================================
# METODOLOGIA DE ENTORNOS (importante): en DESARROLLO estas credenciales apuntan SIEMPRE al
# proyecto de dev (tuvetia-athos-dev), NUNCA al proyecto principal/compartido. Las credenciales
# del principal solo viven en CI / secretos. Detalle: docs/MIGRACIONES.md
# ==========================================================================================

# Supabase (proyecto de DEV — tuvetia-athos-dev)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...          # SECRETA. Solo servidor.
SUPABASE_JWT_SECRET=...                 # Project Settings -> API -> JWT Settings
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres

# Motores de IA (decididos; siempre por env var)
LLM_MODEL=claude-sonnet-5
LLM_LIGHT_MODEL=claude-haiku-4-5
LLM_API_KEY=...                         # console.anthropic.com
EMBEDDING_PROVIDER=cohere
EMBEDDING_MODEL=embed-v4.0              # Cohere (verifica el ID exacto en docs de Cohere)
EMBEDDING_DIM=1024                      # DEBE coincidir con la columna vector de la DB
EMBEDDING_API_KEY=...                   # dashboard.cohere.com

# STT — Modo Fantasma (ADR-0016: Deepgram Nova, batch + diarizacion)
DEEPGRAM_API_KEY=...                    # console.deepgram.com. Requerida para POST /athos/transcribe
STT_MODEL=nova-2                        # modelo de Deepgram; espanol + diarize se fijan en codigo

CORS_ORIGINS=http://localhost:3000
APP_ENV=dev
